{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "染谱 Ranpu",
  "version": "1.0.0",
  "identifier": "com.ranpu.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "染谱 Ranpu",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "fileAssociations": [
      {
        "ext": ["ranpu"],
        "name": "RanpuEncryptedExport",
        "description": "染谱加密导出包",
        "role": "Editor",
        "mimeType": "application/x-ranpu"
      }
    ],
    "category": "Productivity",
    "shortDescription": "染谱 — 离线染纱配色",
    "longDescription": "DDD + Hexagonal architecture 的离线染纱配方与计算软件",
    "copyright": "© 2026 染谱 Ranpu"
  }
}
